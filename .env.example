# ZeroGraph environment overrides (all optional)

MCP_HOST=0.0.0.0
MCP_PORT=4242

ENGINE_CONTAINER_NAME=zg-runtime
ENGINE_BINARY_PATH=cpg-parse
ENGINE_MEMORY_LIMIT=4g
ENGINE_JAVA_OPTS=-Xmx4G -Xms2G -XX:+UseG1GC -Dfile.encoding=UTF-8
ENGINE_PORT_MIN=13371
ENGINE_PORT_MAX=13870

CPG_GENERATION_TIMEOUT=600
MAX_REPO_SIZE_MB=500
QUERY_TIMEOUT=300

WORKSPACE_ROOT=/tmp/zerograph
OTEL_ENABLED=false
OTEL_SERVICE_NAME=zerograph

# Build the analysis runtime image with: docker compose up -d --build
